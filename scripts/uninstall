#!/usr/bin/env bash
set -Eeuo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
ASRYX_LOG_PREFIX="asryx uninstall"
# shellcheck source=scripts/lib/_common.sh
source "${script_dir}/lib/_common.sh"

main() {
  _asryx_require_home

  local owned=(
    "${HOME}/.local/bin/asryx"
    "${HOME}/.local/bin/whisper-cli"
    "${HOME}/.local/opt/asryx"
    "${HOME}/.local/opt/whisper.cpp"
    "${HOME}/.local/share/asryx"
    "${HOME}/.cache/asryx"
    "${HOME}/.asryx.conf"
    "/tmp/asryx-$(id -u)"
  )

  if [[ -n "${XDG_RUNTIME_DIR:-}" ]]; then
    owned+=("${XDG_RUNTIME_DIR}/asryx")
  fi

  local path=""
  for path in "${owned[@]}"; do
    _asryx_remove_one "${path}"
  done

  _asryx_log "done"
}

main "$@"
