#!/usr/bin/env bash
set -Eeuo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
# shellcheck disable=SC2034
ASRYX_LOG_PREFIX="asryx uninstall"
# shellcheck source=scripts/lib/_common.sh
source "${script_dir}/lib/_common.sh"
# shellcheck source=scripts/lib/_paths.sh
source "${script_dir}/lib/_paths.sh"

main() {
  _asryx_require_home

  local runtime_dir="${XDG_RUNTIME_DIR:-}"
  local runtime_asryx=""
  if [[ -n "${runtime_dir}" ]]; then
    runtime_asryx="${runtime_dir}/asryx"
  fi

  local owned=(
    "${HOME}/.local/bin/asryx"
    "${HOME}/.local/bin/whisper-cli"
    "${HOME}/.local/opt/asryx"
    "${HOME}/.local/opt/whisper.cpp"
    "${HOME}/.local/share/asryx"
    "${HOME}/.cache/asryx"
    "${HOME}/.asryx.conf"
  )

  if [[ -n "${runtime_asryx}" ]]; then
    owned+=("${runtime_asryx}")
  fi

  for path in "${owned[@]}"; do
    _asryx_remove_one "${path}"
  done

  _asryx_log "done"
}

main "$@"
