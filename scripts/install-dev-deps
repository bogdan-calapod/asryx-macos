#!/usr/bin/env bash
set -Eeuo pipefail

has() { command -v "$1" >/dev/null 2>&1; }
sudo_cmd() { [ "${EUID:-$(id -u)}" -eq 0 ] || printf '%s' sudo; }
log() { printf '%s\n' "==> $*"; }
err() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

pm=""
if has apt-get; then
  pm="apt"
else
  err "unsupported distro: need apt-get"
fi

log "installing asryx development dependencies (${pm})"
$(sudo_cmd) apt-get update
$(sudo_cmd) apt-get install -y --no-install-recommends \
  bash ca-certificates curl git build-essential cmake ninja-build pkg-config \
  clang clang-format clang-tidy cppcheck shellcheck python3 just \
  pipewire alsa-utils wl-clipboard xclip libnotify-bin
