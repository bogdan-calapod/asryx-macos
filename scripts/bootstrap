#!/usr/bin/env bash
set -Eeuo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
repo_dir="$(cd -- "${script_dir}/.." && pwd -P)"

ASRYX_LOG_PREFIX="asryx bootstrap"
# shellcheck source=scripts/lib/_common.sh
source "${script_dir}/lib/_common.sh"
# shellcheck source=scripts/lib/_deps.sh
source "${script_dir}/lib/_deps.sh"

export GIT_TERMINAL_PROMPT=0

model_name="base.en"
whisper_url="https://github.com/ggerganov/whisper.cpp.git"
whisper_dir="${HOME}/.local/opt/whisper.cpp"

read_whisper_sha() {
  local path="${repo_dir}/versions/whisper-cpp-sha"
  [[ -s "${path}" ]] || _asryx_die "missing whisper.cpp pin: ${path}"
  tr -d '[:space:]' <"${path}"
}

build_asryx() {
  _asryx_log "configuring asryx"
  cmake --fresh --preset release -S "${repo_dir}"

  _asryx_log "building asryx"
  cmake --build "${repo_dir}/build/release" --target asryx
}

install_asryx_binary() {
  local src_bin="${repo_dir}/build/release/asryx"
  local dst_bin="${HOME}/.local/bin/asryx"

  [[ -x "${src_bin}" ]] || _asryx_die "missing built binary: ${src_bin}"
  _asryx_ensure_dir "${HOME}/.local/bin"

  _asryx_log "installing ${dst_bin}"
  install -m 0755 "${src_bin}" "${dst_bin}"
}

write_installed_whisper_pin() {
  local whisper_sha="$1"
  local versions_dir="${HOME}/.local/share/asryx/versions"
  local pin_path="${versions_dir}/whisper-cpp-sha"
  local tmp="${pin_path}.tmp.$$"

  _asryx_ensure_dir "${versions_dir}"
  printf '%s\n' "${whisper_sha}" >"${tmp}"
  mv -f "${tmp}" "${pin_path}"
}

sync_whisper_repo() {
  local whisper_sha="$1"

  _asryx_ensure_dir "${HOME}/.local/opt"

  if [[ -d "${whisper_dir}/.git" ]]; then
    _asryx_log "updating whisper.cpp"
    git -C "${whisper_dir}" fetch --depth 1 origin "${whisper_sha}"
  else
    if [[ -e "${whisper_dir}" ]]; then
      _asryx_die "${whisper_dir} exists but is not a git checkout"
    fi
    _asryx_log "cloning whisper.cpp"
    git clone "${whisper_url}" "${whisper_dir}"
    git -C "${whisper_dir}" fetch --depth 1 origin "${whisper_sha}"
  fi

  git -C "${whisper_dir}" checkout --detach "${whisper_sha}"
  git -C "${whisper_dir}" fsck --no-progress
  git -C "${whisper_dir}" submodule update --init --recursive
}

build_whisper_cli() {
  local build_dir="${whisper_dir}/build/release"

  _asryx_log "configuring whisper.cpp"
  cmake --fresh -S "${whisper_dir}" -B "${build_dir}" -G Ninja -DCMAKE_BUILD_TYPE=Release

  _asryx_log "building whisper-cli"
  cmake --build "${build_dir}" --target whisper-cli
}

install_whisper_cli_binary() {
  local build_dir="${whisper_dir}/build/release"
  local dst_bin="${HOME}/.local/bin/whisper-cli"
  local built=""

  built="$(find "${build_dir}" -type f -name whisper-cli -perm -111 2>/dev/null | head -n 1 || true)"
  [[ -n "${built}" ]] || _asryx_die "could not locate whisper-cli under ${build_dir}"

  _asryx_ensure_dir "${HOME}/.local/bin"
  _asryx_log "installing ${dst_bin}"
  install -m 0755 "${built}" "${dst_bin}"
}

write_default_config_if_missing() {
  local cfg="${HOME}/.asryx.conf"
  [[ -e "${cfg}" ]] && return 0

  _asryx_log "writing ${cfg}"
  printf 'model=%s\n' "${model_name}" >"${cfg}"
}

install_and_select_model() {
  local asryx_bin="${HOME}/.local/bin/asryx"

  [[ -x "${asryx_bin}" ]] || _asryx_die "missing installed binary: ${asryx_bin}"
  "${asryx_bin}" --model install "${model_name}"
  "${asryx_bin}" --model use "${model_name}"
}

warn_path_if_needed() {
  local bin_dir="${HOME}/.local/bin"
  case ":${PATH}:" in
    *":${bin_dir}:"*) return 0 ;;
  esac

  _asryx_log "note: ${bin_dir} is not in PATH"
  _asryx_log "      add: export PATH=\"${bin_dir}:\$PATH\""
}

main() {
  _asryx_require_home
  _asryx_install_runtime_dependencies
  build_asryx

  local whisper_sha=""
  whisper_sha="$(read_whisper_sha)"
  _asryx_log "whisper.cpp pin: ${whisper_sha}"

  install_asryx_binary
  write_installed_whisper_pin "${whisper_sha}"
  sync_whisper_repo "${whisper_sha}"
  build_whisper_cli
  install_whisper_cli_binary
  write_default_config_if_missing
  install_and_select_model
  warn_path_if_needed
}

main "$@"
