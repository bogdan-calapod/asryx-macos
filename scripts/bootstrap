#!/usr/bin/env bash
set -Eeuo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
# shellcheck disable=SC2034
ASRYX_LOG_PREFIX="asryx bootstrap"
# shellcheck source=scripts/lib/_common.sh
source "${script_dir}/lib/_common.sh"
# shellcheck source=scripts/lib/_paths.sh
source "${script_dir}/lib/_paths.sh"
# shellcheck source=scripts/lib/_deps.sh
source "${script_dir}/lib/_deps.sh"
# shellcheck source=scripts/lib/_repos.sh
source "${script_dir}/lib/_repos.sh"

export GIT_TERMINAL_PROMPT=0

repo_url="${ASRYX_REPO_URL:-https://github.com/rccyx/asryx.git}"
repo_ref="${ASRYX_REF:-main}"
repo_dir="${ASRYX_REPO_DIR:-${HOME}/.local/opt/asryx}"
model_name="${ASRYX_MODEL:-base.en}"
whisper_url="${ASRYX_WHISPER_REPO_URL:-https://github.com/ggerganov/whisper.cpp.git}"

resolve_source() {
  local current_root=""

  current_root="$(_asryx_current_repo || true)"
  if [[ -n "${current_root}" ]]; then
    repo_dir="${current_root}"
    _asryx_log "using current asryx checkout: ${repo_dir}"
    return 0
  fi

  _asryx_sync_branch_repo asryx "${repo_url}" "${repo_ref}" "${repo_dir}"
}

read_whisper_sha() {
  local path="${repo_dir}/versions/whisper-cpp-sha"

  [[ -s "${path}" ]] || _asryx_die "missing whisper.cpp pin: ${path}"
  tr -d '[:space:]' <"${path}"
}

build_asryx() {
  _asryx_log "configuring asryx release build in ${repo_dir}/build/release"
  cmake --fresh --preset release -S "${repo_dir}"

  _asryx_log "building asryx"
  cmake --build "${repo_dir}/build/release" --target asryx
}

install_asryx_binary() {
  local src_bin="${repo_dir}/build/release/asryx"
  local dst_bin="${HOME}/.local/bin/asryx"

  [[ -x "${src_bin}" ]] || _asryx_die "expected built binary at ${src_bin}"

  _asryx_ensure_dir "${HOME}/.local/bin"

  _asryx_log "installing asryx to ${dst_bin}"
  install -m 0755 "${src_bin}" "${dst_bin}"
}

write_installed_whisper_pin() {
  local whisper_sha="$1"
  local versions_dir="${HOME}/.local/share/asryx/versions"
  local pin_path="${versions_dir}/whisper-cpp-sha"
  local tmp=""

  _asryx_ensure_dir "${versions_dir}"

  tmp="${pin_path}.tmp.$$"
  printf '%s\n' "${whisper_sha}" >"${tmp}"
  mv -f "${tmp}" "${pin_path}"
}

sync_whisper_repo() {
  local whisper_sha="$1"
  local dir="${HOME}/.local/opt/whisper.cpp"

  _asryx_ensure_dir "${HOME}/.local/opt"
  _asryx_sync_detached_repo whisper.cpp "${whisper_url}" "${whisper_sha}" "${dir}"
}

build_whisper_cli() {
  local dir="${HOME}/.local/opt/whisper.cpp"
  local build_dir="${dir}/build/release"

  _asryx_log "configuring whisper.cpp release build in ${build_dir}"
  cmake --fresh -S "${dir}" -B "${build_dir}" -G Ninja -DCMAKE_BUILD_TYPE=Release

  _asryx_log "building whisper-cli"
  cmake --build "${build_dir}" --target whisper-cli
}

install_whisper_cli_binary() {
  local dir="${HOME}/.local/opt/whisper.cpp"
  local build_dir="${dir}/build/release"
  local dst_bin="${HOME}/.local/bin/whisper-cli"
  local built=""

  _asryx_ensure_dir "${HOME}/.local/bin"

  built="$(
    find "${build_dir}" -type f -name whisper-cli -perm -111 2>/dev/null | head -n 1 || true
  )"

  [[ -n "${built}" ]] || _asryx_die "could not locate built whisper-cli under ${build_dir}"

  _asryx_log "installing whisper-cli to ${dst_bin}"
  install -m 0755 "${built}" "${dst_bin}"
}

write_default_config_if_missing() {
  local cfg="${HOME}/.asryx.conf"
  if [[ -e "${cfg}" ]]; then
    return 0
  fi

  _asryx_log "writing default config (missing): ${cfg}"
  printf 'model=%s\n' "${model_name}" >"${cfg}"
}

install_and_select_model() {
  local asryx_bin="${HOME}/.local/bin/asryx"

  [[ -x "${asryx_bin}" ]] || _asryx_die "expected installed binary at ${asryx_bin}"

  _asryx_log "installing model: ${model_name}"
  "${asryx_bin}" --model install "${model_name}"

  _asryx_log "selecting model: ${model_name}"
  "${asryx_bin}" --model use "${model_name}"
}

warn_path_if_needed() {
  local bin_dir="${HOME}/.local/bin"
  case ":${PATH}:" in
    *":${bin_dir}:"*) return 0 ;;
  esac

  _asryx_log "note: ${bin_dir} is not in PATH"
  _asryx_log "      add it, for example in ~/.profile:"
  _asryx_log "      export PATH=\"${bin_dir}:\$PATH\""
}

main() {
  _asryx_require_home
  _asryx_ensure_runtime_dependencies
  resolve_source
  build_asryx

  local whisper_sha=""
  whisper_sha="$(read_whisper_sha)"
  _asryx_log "whisper.cpp pin: ${whisper_sha}"

  install_asryx_binary
  write_installed_whisper_pin "${whisper_sha}"
  sync_whisper_repo "${whisper_sha}"
  build_whisper_cli
  install_whisper_cli_binary
  write_default_config_if_missing
  install_and_select_model
  warn_path_if_needed
}

main "$@"
