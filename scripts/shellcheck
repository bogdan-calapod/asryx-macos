#!/usr/bin/env bash
set -Eeuo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
# shellcheck source=scripts/lib/_common.sh
source "${script_dir}/lib/_common.sh"

shellcheck_bin="$(_asryx_resolve_tool shellcheck)"
cd "$(_asryx_repo_root)"

"${shellcheck_bin}" -x \
  scripts/bootstrap \
  scripts/fmt \
  scripts/install-dev-deps \
  scripts/lint \
  scripts/resolve-tool \
  scripts/shellcheck \
  scripts/uninstall \
  scripts/lib/_common.sh \
  scripts/lib/_paths.sh \
  scripts/lib/_deps.sh \
  scripts/lib/_repos.sh
