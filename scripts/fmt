#!/usr/bin/env bash
set -Eeuo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
# shellcheck source=scripts/lib/_common.sh
source "${script_dir}/lib/_common.sh"

mode="${1:---check}"
if [[ "${mode}" != "--check" && "${mode}" != "--fix" ]]; then
  printf 'error: unknown format mode: %s\n' "${mode}" >&2
  printf 'hint: use --check or --fix\n' >&2
  exit 2
fi

clang_format="$(_asryx_resolve_tool clang-format)"
cd "$(_asryx_repo_root)"

mapfile -d '' files < <(
  find src tests -type f \
    \( -name '*.cpp' -o -name '*.hpp' -o -name '*.c' -o -name '*.h' \) \
    -print0
)

if ((${#files[@]} == 0)); then
  exit 0
fi

if [[ "${mode}" == "--fix" ]]; then
  "${clang_format}" -i "${files[@]}"
else
  "${clang_format}" --dry-run --Werror "${files[@]}"
fi
