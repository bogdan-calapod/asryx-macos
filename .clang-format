BasedOnStyle: LLVM

Language: Cpp
Standard: c++20

# hard wrap target for readable diffs.
ColumnLimit: 100

# two-space project indentation. no tabs in c++ files.
IndentWidth: 2
ContinuationIndentWidth: 4
TabWidth: 2
UseTab: Never

# keep pointers/references attached to the type: std::string* p, const T& v.
DerivePointerAlignment: false
PointerAlignment: Left
ReferenceAlignment: Left

# align wrapped calls and expressions instead of creating ragged continuation blocks.
AlignAfterOpenBracket: Align
AlignArrayOfStructures: Left
AlignConsecutiveAssignments: false
AlignConsecutiveDeclarations: false
AlignOperands: Align

# avoid compressed function calls/declarations when they wrap.
AllowAllArgumentsOnNextLine: false
AllowAllParametersOfDeclarationOnNextLine: false

# short constructs stay expanded, except empty functions and inline lambdas.
AllowShortBlocksOnASingleLine: Never
AllowShortCaseLabelsOnASingleLine: false
AllowShortEnumsOnASingleLine: false
AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: Never
AllowShortLambdasOnASingleLine: Inline
AllowShortLoopsOnASingleLine: false

AlwaysBreakAfterReturnType: None
AlwaysBreakBeforeMultilineStrings: true

# custom brace layout keeps functions/classes visually heavy without indenting namespace bodies.
BreakBeforeBraces: Custom
BraceWrapping:
  AfterCaseLabel: true
  AfterClass: true
  AfterControlStatement: MultiLine
  AfterEnum: true
  AfterFunction: true
  AfterNamespace: false
  AfterStruct: true
  AfterUnion: true
  BeforeCatch: true
  BeforeElse: true
  IndentBraces: false

# constructor initializer lists become one item per line when they wrap.
BreakConstructorInitializers: BeforeComma
ConstructorInitializerAllOnOneLineOrOnePerLine: false
PackConstructorInitializers: Never

CompactNamespaces: false
Cpp11BracedListStyle: true
FixNamespaceComments: true

# local project includes first, system includes second.
IncludeBlocks: Regroup
IncludeCategories:
  - Regex: '^".*"'
    Priority: 1
  - Regex: "^<.*>$"
    Priority: 2

IndentCaseBlocks: false
IndentCaseLabels: true
IndentPPDirectives: AfterHash

# keep files tight without destroying intentional paragraph breaks.
KeepEmptyLinesAtTheStartOfBlocks: false
MaxEmptyLinesToKeep: 1

NamespaceIndentation: None

ReflowComments: true
SortIncludes: CaseSensitive
SortUsingDeclarations: true

# `if (` not `if(`. function calls stay tight.
SpaceBeforeParens: ControlStatements

SpacesInAngles: Never
SpacesInContainerLiterals: false
