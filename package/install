#!/usr/bin/env bash
[ -n "${BASH_VERSION:-}" ] || exec bash "$0" "$@"

set -Eeuo pipefail
umask 022

timestamp="$(date +%Y%m%d-%H%M%S)"

APP_ID="asryx"
ENGINE_REPO_URL="https://github.com/ggml-org/whisper.cpp.git"

PREFIX="${HOME}/.local"
BUILD_SUBDIR="build"

SHA="040510a132f0a9b51d4692b57a6abfd8c9660696"
MODEL_DEFAULT="base.en"
MODEL_SLUG="${MODEL_DEFAULT}"

AUTO_YES=0

if [ -t 1 ]; then
  red=$'\033[0;31m'
  green=$'\033[0;32m'
  yellow=$'\033[0;33m'
  blue=$'\033[0;34m'
  magenta=$'\033[0;35m'
  cyan=$'\033[0;36m'
  bold=$'\033[1m'
  dim=$'\033[2m'
  nc=$'\033[0m'
else
  red=''; green=''; yellow=''; blue=''; magenta=''; cyan=''; bold=''; dim=''; nc=''
fi

LOG_FILE=""

need_sudo() { if [ "${EUID:-$(id -u)}" -ne 0 ]; then echo sudo; fi; }

_emit() {
  printf "%b\n" "$*"
  if [ -n "${LOG_FILE}" ]; then
    printf "%b\n" "$*" >>"${LOG_FILE}"
  fi
}

die()  { _emit "${red}${bold}error:${nc} $*"; exit 1; }
ok()   { _emit "${green}${bold}✔${nc} $*"; }
warn() { _emit "${yellow}${bold}⚠${nc} $*"; }
info() { _emit "${blue}${bold}i${nc} $*"; }
step() { _emit ""; _emit "${magenta}${bold}==>${nc} $*"; }
hr()   { _emit "${cyan}${dim}------------------------------------------------------------${nc}"; }

ts_now() { date +%s; }
dur() {
  local a="$1" b="$2" d
  d=$((b - a))
  printf "%ss" "${d}"
}

has_cmd() { command -v "$1" >/dev/null 2>&1; }

PM=""
PM_UPDATED=0
PM_PREPARED=0

APT_BUILD_PKGS=(
  ca-certificates
  curl
  git
  build-essential
  cmake
  pkg-config
  ninja-build
)

DNF_BUILD_PKGS=(
  ca-certificates
  curl
  git
  gcc
  gcc-c++
  make
  cmake
  pkgconf-pkg-config
  ninja-build
)

PAC_BUILD_PKGS=(
  ca-certificates
  curl
  git
  gcc
  make
  cmake
  pkgconf
  ninja
)

DEPS_BUILD=()

PKG_AUDIO_PW=""
PKG_AUDIO_ALSA=""
PKG_CLIP_WL=""
PKG_CLIP_X11=""
PKG_NOTIFY=""

usage() {
  cat <<'EOF'
usage:
  ./package/install [--yes|-y] [--model <slug>] [--help]

choices:
  --model <slug>   ggml model slug (default: base.en)

notes:
  - bash-only
  - notifications are mandatory (notify-send must exist)
  - install target is fixed to $HOME/.local
EOF
}

parse_args() {
  while [ "${#}" -gt 0 ]; do
    case "$1" in
      --yes|-y) AUTO_YES=1 ;;
      --model) MODEL_SLUG="${2:-}"; [ -n "${MODEL_SLUG}" ] || die "missing value for --model"; shift ;;
      --help|-h) usage; exit 0 ;;
      *) die "unknown arg: $1 (try --help)" ;;
    esac
    shift
  done
}

log_setup() {
  local cache_dir log_dir
  cache_dir="${XDG_CACHE_HOME:-${HOME}/.cache}"
  log_dir="${cache_dir}/${APP_ID}"
  mkdir -p "${log_dir}"
  LOG_FILE="${log_dir}/install-${timestamp}.log"
  : >"${LOG_FILE}"
  info "log: ${LOG_FILE}"
}

on_err() {
  local code="$?"
  local line="${BASH_LINENO[0]:-?}"
  local cmd="${BASH_COMMAND:-?}"
  _emit ""
  warn "failed (exit ${code})"
  warn "at line: ${line}"
  warn "cmd: ${cmd}"
  warn "log: ${LOG_FILE}"
  exit "${code}"
}

detect_pm() {
  if has_cmd apt-get; then
    PM="apt"
  elif has_cmd dnf; then
    PM="dnf"
  elif has_cmd pacman; then
    PM="pacman"
  else
    die "no supported package manager found (need apt-get, dnf, or pacman)"
  fi
  ok "pm: ${PM}"
}

set_deps_for_pm() {
  case "${PM}" in
    apt)
      DEPS_BUILD=("${APT_BUILD_PKGS[@]}")
      PKG_AUDIO_PW="pipewire"
      PKG_AUDIO_ALSA="alsa-utils"
      PKG_CLIP_WL="wl-clipboard"
      PKG_CLIP_X11="xclip"
      PKG_NOTIFY="libnotify-bin"
      ;;
    dnf)
      DEPS_BUILD=("${DNF_BUILD_PKGS[@]}")
      PKG_AUDIO_PW="pipewire-utils"
      PKG_AUDIO_ALSA="alsa-utils"
      PKG_CLIP_WL="wl-clipboard"
      PKG_CLIP_X11="xclip"
      PKG_NOTIFY="libnotify"
      ;;
    pacman)
      DEPS_BUILD=("${PAC_BUILD_PKGS[@]}")
      PKG_AUDIO_PW="pipewire"
      PKG_AUDIO_ALSA="alsa-utils"
      PKG_CLIP_WL="wl-clipboard"
      PKG_CLIP_X11="xclip"
      PKG_NOTIFY="libnotify"
      ;;
    *)
      die "unsupported package manager: ${PM}"
      ;;
  esac
}

pm_prepare_once() {
  [ "${PM_PREPARED}" -eq 0 ] || return 0
  PM_PREPARED=1

  case "${PM}" in
    apt) has_cmd dpkg || die "dpkg not found (apt detected but dpkg missing)" ;;
    dnf) has_cmd rpm || die "rpm not found (dnf detected but rpm missing)" ;;
    pacman) true ;;
  esac
}

pm_update_once() {
  [ "${PM_UPDATED}" -eq 0 ] || return 0
  PM_UPDATED=1

  step "pm index"
  case "${PM}" in
    apt)
      info "apt-get update"
      $(need_sudo) apt-get update >>"${LOG_FILE}" 2>&1
      ok "apt index updated"
      ;;
    dnf)
      info "dnf makecache"
      $(need_sudo) dnf -y makecache >>"${LOG_FILE}" 2>&1 || true
      ok "dnf cache refreshed"
      ;;
    pacman)
      info "pacman -Sy"
      if has_cmd pacman-key; then
        $(need_sudo) pacman-key --init >>"${LOG_FILE}" 2>&1 || true
        $(need_sudo) pacman-key --populate archlinux >>"${LOG_FILE}" 2>&1 || true
      fi
      $(need_sudo) pacman -Sy --noconfirm >>"${LOG_FILE}" 2>&1 || true
      ok "pacman sync done"
      ;;
  esac
}

pkg_installed() {
  case "${PM}" in
    apt) dpkg -s "$1" >/dev/null 2>&1 ;;
    dnf) rpm -q "$1" >/dev/null 2>&1 ;;
    pacman) pacman -Qi "$1" >/dev/null 2>&1 ;;
    *) return 1 ;;
  esac
}

pm_install_many() {
  pm_prepare_once
  pm_update_once

  step "pm install"
  info "installing: $*"
  case "${PM}" in
    apt)
      $(need_sudo) apt-get install -y --no-install-recommends "$@" >>"${LOG_FILE}" 2>&1
      ;;
    dnf)
      $(need_sudo) dnf -y install --setopt=install_weak_deps=False "$@" >>"${LOG_FILE}" 2>&1
      ;;
    pacman)
      $(need_sudo) pacman -S --noconfirm --needed "$@" >>"${LOG_FILE}" 2>&1
      ;;
    *)
      die "unsupported package manager: ${PM}"
      ;;
  esac
  ok "installed: $*"
}

install_missing_pkgs() {
  local missing=() p
  for p in "$@"; do
    [ -n "${p}" ] || continue
    pkg_installed "$p" || missing+=("$p")
  done
  if [ "${#missing[@]}" -eq 0 ]; then
    ok "deps already present"
    return 0
  fi
  pm_install_many "${missing[@]}"
}

confirm_plan() {
  if [ "${AUTO_YES}" -eq 1 ]; then
    ok "auto mode: skipping confirmation (--yes/-y)"
    return 0
  fi
  _emit ""
  info "this will install packages via ${PM} and write under: ${PREFIX}"
  info "type ${bold}y${nc} to proceed"
  printf "%bproceed?%b " "${cyan}" "${nc}"
  local ans
  IFS= read -r ans || true
  [ "${ans:-}" = "y" ] || die "aborted"
}

sudo_warmup() {
  step "sudo"
  if [ "${EUID:-$(id -u)}" -eq 0 ]; then
    die "refusing to run as root"
  fi
  has_cmd sudo || die "sudo not found (install sudo)"
  info "sudo is required for system deps"
  if sudo -n true >/dev/null 2>&1; then
    ok "sudo: non-interactive ok"
    return 0
  fi
  sudo -v >/dev/null 2>&1 || die "sudo auth failed"
  ok "sudo ok"
}

sha256() { sha256sum "$1" | awk '{print $1}'; }

SCRIPT_DIR=""
ROOT=""
BUILD=""
BIN_DIR=""
SHARE_DIR=""
MODELS_DIR=""
ENV_FILE=""
MANIFEST=""

set_paths() {
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  ROOT="${PREFIX}/opt/whisper.cpp"
  BUILD="${ROOT}/${BUILD_SUBDIR}"
  BIN_DIR="${PREFIX}/bin"
  SHARE_DIR="${PREFIX}/share/${APP_ID}"
  MODELS_DIR="${SHARE_DIR}/models"
  ENV_FILE="${SHARE_DIR}/asryx.env"
  MANIFEST="${SHARE_DIR}/install.manifest"
}

session_type() {
  if [ "${XDG_SESSION_TYPE:-}" = "wayland" ] || [ -n "${WAYLAND_DISPLAY:-}" ]; then
    echo "wayland"
  elif [ "${XDG_SESSION_TYPE:-}" = "x11" ] || [ -n "${DISPLAY:-}" ]; then
    echo "x11"
  else
    echo "unknown"
  fi
}

print_plan() {
  step "plan"
  hr
  _emit "${bold}asryx installer${nc}"
  _emit ""
  _emit "prefix:     ${PREFIX}"
  _emit "repo:       ${ENGINE_REPO_URL}"
  _emit "commit:     ${SHA}"
  _emit "workspace:  ${ROOT}"
  _emit "build dir:  ${BUILD}"
  _emit "bin dir:    ${BIN_DIR}"
  _emit "share dir:  ${SHARE_DIR}"
  _emit "models dir: ${MODELS_DIR}"
  _emit "contract:   ${ENV_FILE}"
  _emit "manifest:   ${MANIFEST}"
  _emit "pm:         ${PM}"
  _emit "model:      ${MODEL_SLUG}"
  _emit "session:    $(session_type)"
  hr
  _emit "will do:"
  _emit "  - install build deps (${PM})"
  _emit "  - ensure runtime contract tools exist (recorder + clipboard + notify)"
  _emit "  - clone/update engine repo and hard-checkout pinned commit"
  _emit "  - build Release engine"
  _emit "  - install engine binaries into <prefix>/bin"
  _emit "  - install toggle into <prefix>/bin/asryx"
  _emit "  - install model into <prefix>/share/asryx/models"
  _emit "  - write contract to <prefix>/share/asryx/asryx.env"
  _emit "  - write manifest for safe uninstall"
  _emit ""
  hr
}

ensure_runtime_contract() {
  step "runtime contract"

  if has_cmd notify-send; then
    ok "notify: notify-send (present)"
  else
    info "notify: missing -> installing (${PKG_NOTIFY})"
    pm_install_many "${PKG_NOTIFY}"
    has_cmd notify-send || die "notify-send still missing after install (${PKG_NOTIFY})"
    ok "notify: notify-send (installed)"
  fi

  if has_cmd pw-record; then
    ok "audio: pw-record (present)"
  elif has_cmd arecord; then
    ok "audio: arecord (present)"
  else
    info "audio: no recorder found -> installing preferred (${PKG_AUDIO_PW})"
    pm_install_many "${PKG_AUDIO_PW}" || true
    if has_cmd pw-record; then
      ok "audio: pw-record (installed)"
    fi
    if ! has_cmd pw-record && ! has_cmd arecord; then
      info "audio: installing fallback (${PKG_AUDIO_ALSA})"
      pm_install_many "${PKG_AUDIO_ALSA}"
      has_cmd arecord || die "arecord still missing after install (${PKG_AUDIO_ALSA})"
      ok "audio: arecord (installed)"
    fi
  fi

  local st
  st="$(session_type)"

  if [ "${st}" = "wayland" ]; then
    if has_cmd wl-copy; then
      ok "clipboard: wl-copy (present)"
    else
      info "clipboard: missing wl-copy -> installing (${PKG_CLIP_WL})"
      pm_install_many "${PKG_CLIP_WL}"
      has_cmd wl-copy || die "wl-copy still missing after install (${PKG_CLIP_WL})"
      ok "clipboard: wl-copy (installed)"
    fi
  elif [ "${st}" = "x11" ]; then
    if has_cmd xclip; then
      ok "clipboard: xclip (present)"
    else
      info "clipboard: missing xclip -> installing (${PKG_CLIP_X11})"
      pm_install_many "${PKG_CLIP_X11}"
      has_cmd xclip || die "xclip still missing after install (${PKG_CLIP_X11})"
      ok "clipboard: xclip (installed)"
    fi
  else
    if has_cmd wl-copy || has_cmd xclip; then
      ok "clipboard: provider present"
    else
      warn "clipboard: session unknown -> installing both providers"
      pm_install_many "${PKG_CLIP_WL}" "${PKG_CLIP_X11}" || true
      if ! has_cmd wl-copy && ! has_cmd xclip; then
        pm_install_many "${PKG_CLIP_WL}" || true
        pm_install_many "${PKG_CLIP_X11}" || true
      fi
      (has_cmd wl-copy || has_cmd xclip) || die "no clipboard tool after install"
      ok "clipboard: provider installed"
    fi
  fi

  has_cmd notify-send || die "runtime contract failed: notify-send missing"
  (has_cmd pw-record || has_cmd arecord) || die "runtime contract failed: no recorder (pw-record/arecord)"
  (has_cmd wl-copy || has_cmd xclip) || die "runtime contract failed: no clipboard (wl-copy/xclip)"
  ok "runtime contract satisfied"
}

clone_or_update() {
  step "source"
  mkdir -p "${PREFIX}/opt"

  if [ -d "${ROOT}/.git" ]; then
    ok "repo exists: ${ROOT}"
    git -C "${ROOT}" fetch --all --tags --prune >>"${LOG_FILE}" 2>&1
  else
    ok "cloning: ${ENGINE_REPO_URL} -> ${ROOT}"
    git clone "${ENGINE_REPO_URL}" "${ROOT}" >>"${LOG_FILE}" 2>&1
  fi

  git -C "${ROOT}" cat-file -e "${SHA}^{commit}" >>"${LOG_FILE}" 2>&1 || die "commit not found: ${SHA}"
  git -C "${ROOT}" checkout -f "${SHA}" >>"${LOG_FILE}" 2>&1
  git -C "${ROOT}" reset --hard "${SHA}" >>"${LOG_FILE}" 2>&1
  git -C "${ROOT}" submodule update --init --recursive >>"${LOG_FILE}" 2>&1 || true
  ok "source pinned: ${SHA}"
}

nproc_fallback() {
  if has_cmd nproc; then
    nproc
  else
    echo 4
  fi
}

build_release() {
  step "build"
  mkdir -p "${BUILD}"

  local t0 t1
  t0="$(ts_now)"
  info "configuring (cmake)"
  cmake -S "${ROOT}" -B "${BUILD}" -DCMAKE_BUILD_TYPE=Release >>"${LOG_FILE}" 2>&1
  info "building (n=$(nproc_fallback))"
  cmake --build "${BUILD}" --parallel "$(nproc_fallback)" >>"${LOG_FILE}" 2>&1
  t1="$(ts_now)"

  local cli="${BUILD}/bin/whisper-cli"
  [ -x "${cli}" ] || die "build did not produce whisper-cli at ${cli}"
  ok "built whisper-cli ($(dur "${t0}" "${t1}"))"

  if [ -x "${BUILD}/bin/whisper-stream" ]; then
    ok "built whisper-stream"
  else
    warn "whisper-stream not built (ok)"
  fi
}

install_binaries_atomic() {
  step "install (engine bin)"
  mkdir -p "${BIN_DIR}"

  local stage="${BIN_DIR}/.${APP_ID}.stage.${timestamp}"
  mkdir -p "${stage}"

  local cli_src="${BUILD}/bin/whisper-cli"
  local cli_dst="${BIN_DIR}/whisper-cli"
  local cli_bak="${BIN_DIR}/.whisper-cli.bak.${timestamp}"

  [ -x "${cli_src}" ] || die "missing built binary: ${cli_src}"
  install -m 0755 "${cli_src}" "${stage}/whisper-cli"

  if [ -f "${cli_dst}" ] || [ -L "${cli_dst}" ]; then
    mv -f "${cli_dst}" "${cli_bak}" >>"${LOG_FILE}" 2>&1 || true
  fi
  mv -f "${stage}/whisper-cli" "${cli_dst}"
  rm -rf "${stage}" >>"${LOG_FILE}" 2>&1 || true
  rm -f "${cli_bak}" >>"${LOG_FILE}" 2>&1 || true
  ok "installed: ${cli_dst}"

  if [ -x "${BUILD}/bin/whisper-stream" ]; then
    local stream_src="${BUILD}/bin/whisper-stream"
    local stream_dst="${BIN_DIR}/whisper-stream"
    local stream_bak="${BIN_DIR}/.whisper-stream.bak.${timestamp}"
    local stage2="${BIN_DIR}/.${APP_ID}.stage2.${timestamp}"
    mkdir -p "${stage2}"
    install -m 0755 "${stream_src}" "${stage2}/whisper-stream"
    if [ -f "${stream_dst}" ] || [ -L "${stream_dst}" ]; then
      mv -f "${stream_dst}" "${stream_bak}" >>"${LOG_FILE}" 2>&1 || true
    fi
    mv -f "${stage2}/whisper-stream" "${stream_dst}"
    rm -rf "${stage2}" >>"${LOG_FILE}" 2>&1 || true
    rm -f "${stream_bak}" >>"${LOG_FILE}" 2>&1 || true
    ok "installed: ${stream_dst}"
  fi
}

download_model() {
  step "install (model)"
  mkdir -p "${MODELS_DIR}"
  local model_file="${MODELS_DIR}/ggml-${MODEL_SLUG}.bin"

  if [ -s "${model_file}" ]; then
    ok "model already present: $(basename "${model_file}")"
    return 0
  fi

  local dl="${ROOT}/models/download-ggml-model.sh"
  [ -f "${dl}" ] || die "missing model downloader: ${dl}"

  info "downloading: ${MODEL_SLUG}"
  ( cd "${ROOT}" && bash "./models/download-ggml-model.sh" "${MODEL_SLUG}" ) >>"${LOG_FILE}" 2>&1
  local downloaded="${ROOT}/models/ggml-${MODEL_SLUG}.bin"
  [ -s "${downloaded}" ] || die "model download failed: ${downloaded}"
  install -m 0644 "${downloaded}" "${model_file}"
  ok "model installed: $(basename "${model_file}")"
}

install_toggle() {
  step "install (toggle)"
  mkdir -p "${BIN_DIR}"

  local src="${SCRIPT_DIR}/asryx"
  [ -f "${src}" ] || die "toggle file not found next to installer: ${src}"

  local dst="${BIN_DIR}/asryx"
  install -m 0755 "${src}" "${dst}"
  ok "installed: ${dst}"
}

write_contract() {
  step "contract"
  mkdir -p "${SHARE_DIR}"

  local engine="${BIN_DIR}/whisper-cli"
  local model="${MODELS_DIR}/ggml-${MODEL_SLUG}.bin"

  {
    echo "ASRYX_ENGINE=${engine}"
    echo "ASRYX_MODEL=${model}"
  } > "${ENV_FILE}"

  ok "wrote: ${ENV_FILE}"
}

write_manifest() {
  step "manifest"
  mkdir -p "${SHARE_DIR}"

  local engine="${BIN_DIR}/whisper-cli"
  local stream="${BIN_DIR}/whisper-stream"
  local toggle="${BIN_DIR}/asryx"
  local model="${MODELS_DIR}/ggml-${MODEL_SLUG}.bin"

  {
    echo "app_id=${APP_ID}"
    echo "timestamp=${timestamp}"
    echo "prefix=${PREFIX}"
    echo "engine_repo_url=${ENGINE_REPO_URL}"
    echo "engine_sha=${SHA}"
    echo "workspace=${ROOT}"
    echo "build_dir=${BUILD}"
    echo "bin_dir=${BIN_DIR}"
    echo "share_dir=${SHARE_DIR}"
    echo "models_dir=${MODELS_DIR}"
    echo "env_path=${ENV_FILE}"
    echo "env_sha256=$(sha256 "${ENV_FILE}")"

    echo "engine_cli_path=${engine}"
    echo "engine_cli_sha256=$(sha256 "${engine}")"

    if [ -x "${stream}" ]; then
      echo "engine_stream_path=${stream}"
      echo "engine_stream_sha256=$(sha256 "${stream}")"
    else
      echo "engine_stream_path="
      echo "engine_stream_sha256="
    fi

    echo "toggle_path=${toggle}"
    echo "toggle_sha256=$(sha256 "${toggle}")"

    echo "model_slug=${MODEL_SLUG}"
    echo "model_path=${model}"
    echo "model_sha256=$(sha256 "${model}")"
  } > "${MANIFEST}"

  ok "wrote: ${MANIFEST}"
}

verify_install() {
  step "verify"
  [ -x "${BIN_DIR}/whisper-cli" ] || die "missing: ${BIN_DIR}/whisper-cli"
  "${BIN_DIR}/whisper-cli" --help >>"${LOG_FILE}" 2>&1 || die "whisper-cli failed to run"
  [ -x "${BIN_DIR}/asryx" ] || die "missing: ${BIN_DIR}/asryx"
  ok "engine ok"
  ok "toggle ok"

  has_cmd notify-send || die "missing runtime tool: notify-send"
  (has_cmd pw-record || has_cmd arecord) || die "missing runtime tool: pw-record/arecord"
  (has_cmd wl-copy || has_cmd xclip) || die "missing runtime tool: wl-copy/xclip"
  ok "runtime tools ok"

  local model_file="${MODELS_DIR}/ggml-${MODEL_SLUG}.bin"
  [ -s "${model_file}" ] || die "missing model: ${model_file}"
  ok "model ok"

  _emit ""
  hr
  _emit "${bold}usage:${nc}"
  _emit "  asryx"
  _emit ""
  _emit "${bold}hyprland example:${nc}"
  _emit "  bind = ALT, W, exec, asryx"
  hr
}

main() {
  trap on_err ERR

  local t_all0 t_all1
  t_all0="$(ts_now)"

  parse_args "$@"
  log_setup

  detect_pm
  set_deps_for_pm
  pm_prepare_once

  set_paths
  print_plan
  confirm_plan
  sudo_warmup

  step "deps (build)"
  install_missing_pkgs "${DEPS_BUILD[@]}"
  ok "build deps satisfied"

  ensure_runtime_contract

  clone_or_update
  build_release
  install_binaries_atomic
  download_model
  install_toggle
  write_contract
  write_manifest
  verify_install

  t_all1="$(ts_now)"
  step "done"
  ok "installed asryx ($(dur "${t_all0}" "${t_all1}"))"
  ok "log: ${LOG_FILE}"
}

main "$@"
