#!/usr/bin/env bash
[ -n "${BASH_VERSION:-}" ] || exec bash "$0" "$@"

set -Eeuo pipefail
umask 022

timestamp="$(date +%Y%m%d-%H%M%S)"

APP_ID="asryx"
ENGINE_REPO_URL="https://github.com/ggml-org/whisper.cpp.git"

PREFIX="${HOME}/.local"
BUILD_SUBDIR="build"

ENGINE_SHA="040510a132f0a9b51d4692b57a6abfd8c9660696"

AUTO_YES=0
MODEL_SLUGS=()

if [ -t 1 ]; then
  red=$'\033[0;31m'
  green=$'\033[0;32m'
  yellow=$'\033[0;33m'
  blue=$'\033[0;34m'
  magenta=$'\033[0;35m'
  cyan=$'\033[0;36m'
  bold=$'\033[1m'
  dim=$'\033[2m'
  nc=$'\033[0m'
else
  red=''; green=''; yellow=''; blue=''; magenta=''; cyan=''; bold=''; dim=''; nc=''
fi

LOG_FILE=""

_emit() {
  printf "%b\n" "$*"
  if [ -n "${LOG_FILE}" ]; then
    printf "%b\n" "$*" >>"${LOG_FILE}"
  fi
}

die()  { _emit "${red}${bold}error:${nc} $*"; exit 1; }
ok()   { _emit "${green}${bold}✔${nc} $*"; }
warn() { _emit "${yellow}${bold}⚠${nc} $*"; }
info() { _emit "${blue}${bold}i${nc} $*"; }
step() { _emit ""; _emit "${magenta}${bold}==>${nc} $*"; }
hr()   { _emit "${cyan}${dim}------------------------------------------------------------${nc}"; }

has_cmd() { command -v "$1" >/dev/null 2>&1; }
need_sudo() { if [ "${EUID:-$(id -u)}" -ne 0 ]; then echo sudo; fi; }

ts_now() { date +%s; }
dur() { local a="$1" b="$2"; printf "%ss" "$((b - a))"; }

usage() {
  cat <<'EOF'
usage:
  ./package/install [--yes|-y] [--model <slug>]... [--help]

notes:
  - you can pass --model multiple times
  - re-running install with a new model installs it next to existing models
EOF
}

is_safe_slug() {
  local s="$1"
  [[ "$s" =~ ^[a-z0-9][a-z0-9._-]*$ ]]
}

parse_args() {
  while [ "${#}" -gt 0 ]; do
    case "$1" in
      --yes|-y) AUTO_YES=1 ;;
      --model)
        [ -n "${2:-}" ] || die "missing value for --model"
        is_safe_slug "${2}" || die "invalid model slug: ${2}"
        MODEL_SLUGS+=("${2}")
        shift
        ;;
      --help|-h) usage; exit 0 ;;
      *) die "unknown arg: $1 (try --help)" ;;
    esac
    shift
  done
  if [ "${#MODEL_SLUGS[@]}" -eq 0 ]; then
    MODEL_SLUGS=("base.en")
  fi
}

log_setup() {
  local cache_dir log_dir
  cache_dir="${XDG_CACHE_HOME:-${HOME}/.cache}"
  log_dir="${cache_dir}/${APP_ID}"
  mkdir -p "${log_dir}"
  LOG_FILE="${log_dir}/install-${timestamp}.log"
  : >"${LOG_FILE}"
  info "log: ${LOG_FILE}"
}

on_err() {
  local code="$?"
  local line="${BASH_LINENO[0]:-?}"
  local cmd="${BASH_COMMAND:-?}"
  _emit ""
  warn "failed (exit ${code})"
  warn "at line: ${line}"
  warn "cmd: ${cmd}"
  warn "log: ${LOG_FILE}"
  exit "${code}"
}

PM=""
PM_UPDATED=0
PM_PREPARED=0

APT_BUILD_PKGS=(ca-certificates curl git build-essential cmake pkg-config ninja-build)
DNF_BUILD_PKGS=(ca-certificates curl git gcc gcc-c++ make cmake pkgconf-pkg-config ninja-build)
PAC_BUILD_PKGS=(ca-certificates curl git gcc make cmake pkgconf ninja)

DEPS_BUILD=()

PKG_AUDIO_PW=""
PKG_AUDIO_ALSA=""
PKG_CLIP_WL=""
PKG_CLIP_X11=""
PKG_NOTIFY=""

detect_pm() {
  if has_cmd apt-get; then
    PM="apt"
  elif has_cmd dnf; then
    PM="dnf"
  elif has_cmd pacman; then
    PM="pacman"
  else
    die "no supported package manager found (need apt-get, dnf, or pacman)"
  fi
  ok "pm: ${PM}"
}

set_deps_for_pm() {
  case "${PM}" in
    apt)
      DEPS_BUILD=("${APT_BUILD_PKGS[@]}")
      PKG_AUDIO_PW="pipewire"
      PKG_AUDIO_ALSA="alsa-utils"
      PKG_CLIP_WL="wl-clipboard"
      PKG_CLIP_X11="xclip"
      PKG_NOTIFY="libnotify-bin"
      ;;
    dnf)
      DEPS_BUILD=("${DNF_BUILD_PKGS[@]}")
      PKG_AUDIO_PW="pipewire-utils"
      PKG_AUDIO_ALSA="alsa-utils"
      PKG_CLIP_WL="wl-clipboard"
      PKG_CLIP_X11="xclip"
      PKG_NOTIFY="libnotify"
      ;;
    pacman)
      DEPS_BUILD=("${PAC_BUILD_PKGS[@]}")
      PKG_AUDIO_PW="pipewire"
      PKG_AUDIO_ALSA="alsa-utils"
      PKG_CLIP_WL="wl-clipboard"
      PKG_CLIP_X11="xclip"
      PKG_NOTIFY="libnotify"
      ;;
    *) die "unsupported package manager: ${PM}" ;;
  esac
}

pm_prepare_once() {
  [ "${PM_PREPARED}" -eq 0 ] || return 0
  PM_PREPARED=1
  case "${PM}" in
    apt) has_cmd dpkg || die "dpkg not found (apt detected but dpkg missing)" ;;
    dnf) has_cmd rpm || die "rpm not found (dnf detected but rpm missing)" ;;
    pacman) true ;;
  esac
}

pm_update_once() {
  [ "${PM_UPDATED}" -eq 0 ] || return 0
  PM_UPDATED=1
  step "pm index"
  case "${PM}" in
    apt)
      info "apt-get update"
      $(need_sudo) apt-get update >>"${LOG_FILE}" 2>&1
      ok "apt index updated"
      ;;
    dnf)
      info "dnf makecache"
      $(need_sudo) dnf -y makecache >>"${LOG_FILE}" 2>&1 || true
      ok "dnf cache refreshed"
      ;;
    pacman)
      info "pacman -Sy"
      if has_cmd pacman-key; then
        $(need_sudo) pacman-key --init >>"${LOG_FILE}" 2>&1 || true
        $(need_sudo) pacman-key --populate archlinux >>"${LOG_FILE}" 2>&1 || true
      fi
      $(need_sudo) pacman -Sy --noconfirm >>"${LOG_FILE}" 2>&1 || true
      ok "pacman sync done"
      ;;
  esac
}

pkg_installed() {
  case "${PM}" in
    apt) dpkg -s "$1" >/dev/null 2>&1 ;;
    dnf) rpm -q "$1" >/dev/null 2>&1 ;;
    pacman) pacman -Qi "$1" >/dev/null 2>&1 ;;
    *) return 1 ;;
  esac
}

pm_install_many() {
  pm_prepare_once
  pm_update_once
  step "pm install"
  info "installing: $*"
  case "${PM}" in
    apt) $(need_sudo) apt-get install -y --no-install-recommends "$@" >>"${LOG_FILE}" 2>&1 ;;
    dnf) $(need_sudo) dnf -y install --setopt=install_weak_deps=False "$@" >>"${LOG_FILE}" 2>&1 ;;
    pacman) $(need_sudo) pacman -S --noconfirm --needed "$@" >>"${LOG_FILE}" 2>&1 ;;
    *) die "unsupported package manager: ${PM}" ;;
  esac
  ok "installed: $*"
}

install_missing_pkgs() {
  local missing=() p
  for p in "$@"; do
    [ -n "${p}" ] || continue
    pkg_installed "$p" || missing+=("$p")
  done
  if [ "${#missing[@]}" -eq 0 ]; then
    ok "deps already present"
    return 0
  fi
  pm_install_many "${missing[@]}"
}

session_type() {
  if [ "${XDG_SESSION_TYPE:-}" = "wayland" ] || [ -n "${WAYLAND_DISPLAY:-}" ]; then
    echo "wayland"
  elif [ "${XDG_SESSION_TYPE:-}" = "x11" ] || [ -n "${DISPLAY:-}" ]; then
    echo "x11"
  else
    echo "unknown"
  fi
}

confirm_plan() {
  if [ "${AUTO_YES}" -eq 1 ]; then
    ok "auto mode: skipping confirmation (--yes/-y)"
    return 0
  fi
  _emit ""
  info "type ${bold}y${nc} to proceed"
  printf "%bproceed?%b " "${cyan}" "${nc}"
  local ans
  IFS= read -r ans || true
  [ "${ans:-}" = "y" ] || die "aborted"
}

sudo_warmup() {
  step "sudo"
  if [ "${EUID:-$(id -u)}" -eq 0 ]; then
    die "refusing to run as root"
  fi
  has_cmd sudo || die "sudo not found (install sudo)"
  if sudo -n true >/dev/null 2>&1; then
    ok "sudo: non-interactive ok"
    return 0
  fi
  sudo -v >/dev/null 2>&1 || die "sudo auth failed"
  ok "sudo ok"
}

sha256() { sha256sum "$1" | awk '{print $1}'; }

SCRIPT_DIR=""
ROOT=""
BUILD=""
BIN_DIR=""
SHARE_DIR=""
MODELS_DIR=""
CONTRACT_FILE=""
MANIFEST_FILE=""
USER_ENV_FILE=""

set_paths() {
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  ROOT="${PREFIX}/opt/whisper.cpp"
  BUILD="${ROOT}/${BUILD_SUBDIR}"
  BIN_DIR="${PREFIX}/bin"
  SHARE_DIR="${PREFIX}/share/${APP_ID}"
  MODELS_DIR="${SHARE_DIR}/models"
  CONTRACT_FILE="${SHARE_DIR}/asryx.env"
  MANIFEST_FILE="${SHARE_DIR}/install.manifest"
  USER_ENV_FILE="${HOME}/.asryx.env"
}

print_plan() {
  step "plan"
  hr
  _emit "${bold}asryx installer${nc}"
  _emit ""
  _emit "prefix:        ${PREFIX}"
  _emit "repo:          ${ENGINE_REPO_URL}"
  _emit "engine commit: ${ENGINE_SHA}"
  _emit "workspace:     ${ROOT}"
  _emit "build dir:     ${BUILD}"
  _emit "bin dir:       ${BIN_DIR}"
  _emit "share dir:     ${SHARE_DIR}"
  _emit "models dir:    ${MODELS_DIR}"
  _emit "contract:      ${CONTRACT_FILE}"
  _emit "manifest:      ${MANIFEST_FILE}"
  _emit "user config:   ${USER_ENV_FILE}"
  _emit "pm:            ${PM}"
  _emit "session:       $(session_type)"
  _emit "models:        ${MODEL_SLUGS[*]}"
  hr
  _emit "will do:"
  _emit "  - install build deps (${PM})"
  _emit "  - enforce runtime contract tools exist (recorder + clipboard + notify)"
  _emit "  - clone/update engine repo and hard-checkout pinned commit"
  _emit "  - build Release whisper-cli (or verify existing install)"
  _emit "  - install whisper-cli into <prefix>/bin"
  _emit "  - install asryx toggle into <prefix>/bin/asryx"
  _emit "  - download and install requested model(s) into <prefix>/share/asryx/models"
  _emit "  - write internal contract + uninstall manifest"
  _emit "  - create ~/.asryx.env if missing (sets ASRYX_MODEL once)"
  hr
}

ensure_runtime_contract() {
  step "runtime contract"

  if has_cmd notify-send; then
    ok "notify: notify-send (present)"
  else
    info "notify: missing -> installing (${PKG_NOTIFY})"
    pm_install_many "${PKG_NOTIFY}"
    has_cmd notify-send || die "notify-send still missing after install (${PKG_NOTIFY})"
    ok "notify: notify-send (installed)"
  fi

  if has_cmd pw-record; then
    ok "audio: pw-record (present)"
  elif has_cmd arecord; then
    ok "audio: arecord (present)"
  else
    info "audio: no recorder found -> installing preferred (${PKG_AUDIO_PW})"
    pm_install_many "${PKG_AUDIO_PW}" || true
    if has_cmd pw-record; then ok "audio: pw-record (installed)"; fi
    if ! has_cmd pw-record && ! has_cmd arecord; then
      info "audio: installing fallback (${PKG_AUDIO_ALSA})"
      pm_install_many "${PKG_AUDIO_ALSA}"
      has_cmd arecord || die "arecord still missing after install (${PKG_AUDIO_ALSA})"
      ok "audio: arecord (installed)"
    fi
  fi

  local st
  st="$(session_type)"

  if [ "${st}" = "wayland" ]; then
    if has_cmd wl-copy; then
      ok "clipboard: wl-copy (present)"
    else
      info "clipboard: missing wl-copy -> installing (${PKG_CLIP_WL})"
      pm_install_many "${PKG_CLIP_WL}"
      has_cmd wl-copy || die "wl-copy still missing after install (${PKG_CLIP_WL})"
      ok "clipboard: wl-copy (installed)"
    fi
  elif [ "${st}" = "x11" ]; then
    if has_cmd xclip; then
      ok "clipboard: xclip (present)"
    else
      info "clipboard: missing xclip -> installing (${PKG_CLIP_X11})"
      pm_install_many "${PKG_CLIP_X11}"
      has_cmd xclip || die "xclip still missing after install (${PKG_CLIP_X11})"
      ok "clipboard: xclip (installed)"
    fi
  else
    if has_cmd wl-copy || has_cmd xclip; then
      ok "clipboard: provider present"
    else
      warn "clipboard: session unknown -> installing both providers"
      pm_install_many "${PKG_CLIP_WL}" "${PKG_CLIP_X11}" || true
      (has_cmd wl-copy || has_cmd xclip) || die "no clipboard tool after install"
      ok "clipboard: provider installed"
    fi
  fi

  has_cmd notify-send || die "runtime contract failed: notify-send missing"
  (has_cmd pw-record || has_cmd arecord) || die "runtime contract failed: no recorder (pw-record/arecord)"
  (has_cmd wl-copy || has_cmd xclip) || die "runtime contract failed: no clipboard (wl-copy/xclip)"
  ok "runtime contract satisfied"
}

clone_or_update() {
  step "source"
  mkdir -p "${PREFIX}/opt"

  if [ -d "${ROOT}/.git" ]; then
    ok "repo exists: ${ROOT}"
    git -C "${ROOT}" fetch --all --tags --prune >>"${LOG_FILE}" 2>&1
  else
    ok "cloning: ${ENGINE_REPO_URL} -> ${ROOT}"
    git clone "${ENGINE_REPO_URL}" "${ROOT}" >>"${LOG_FILE}" 2>&1
  fi

  git -C "${ROOT}" cat-file -e "${ENGINE_SHA}^{commit}" >>"${LOG_FILE}" 2>&1 || die "commit not found: ${ENGINE_SHA}"
  git -C "${ROOT}" checkout -f "${ENGINE_SHA}" >>"${LOG_FILE}" 2>&1
  git -C "${ROOT}" reset --hard "${ENGINE_SHA}" >>"${LOG_FILE}" 2>&1
  git -C "${ROOT}" submodule update --init --recursive >>"${LOG_FILE}" 2>&1 || true
  ok "source pinned: ${ENGINE_SHA}"
}

nproc_fallback() { has_cmd nproc && nproc || echo 4; }

build_release() {
  step "build"
  mkdir -p "${BUILD}"

  local t0 t1
  t0="$(ts_now)"
  info "configuring (cmake)"
  cmake -S "${ROOT}" -B "${BUILD}" -DCMAKE_BUILD_TYPE=Release >>"${LOG_FILE}" 2>&1
  info "building (n=$(nproc_fallback))"
  cmake --build "${BUILD}" --parallel "$(nproc_fallback)" >>"${LOG_FILE}" 2>&1
  t1="$(ts_now)"

  local cli="${BUILD}/bin/whisper-cli"
  [ -x "${cli}" ] || die "build did not produce whisper-cli at ${cli}"
  ok "built whisper-cli ($(dur "${t0}" "${t1}"))"
}

install_engine_atomic() {
  step "install (engine)"
  mkdir -p "${BIN_DIR}"

  local cli_src="${BUILD}/bin/whisper-cli"
  local cli_dst="${BIN_DIR}/whisper-cli"
  [ -x "${cli_src}" ] || die "missing built binary: ${cli_src}"

  local stage="${BIN_DIR}/.${APP_ID}.stage.${timestamp}"
  mkdir -p "${stage}"
  install -m 0755 "${cli_src}" "${stage}/whisper-cli"

  local bak="${BIN_DIR}/.whisper-cli.bak.${timestamp}"
  if [ -f "${cli_dst}" ] || [ -L "${cli_dst}" ]; then
    mv -f "${cli_dst}" "${bak}" >>"${LOG_FILE}" 2>&1 || true
  fi
  mv -f "${stage}/whisper-cli" "${cli_dst}"
  rm -rf "${stage}" >>"${LOG_FILE}" 2>&1 || true
  rm -f "${bak}" >>"${LOG_FILE}" 2>&1 || true
  ok "installed: ${cli_dst}"
}

install_toggle() {
  step "install (toggle)"
  mkdir -p "${BIN_DIR}"
  local src="${SCRIPT_DIR}/asryx"
  local dst="${BIN_DIR}/asryx"
  [ -f "${src}" ] || die "toggle file not found: ${src}"
  install -m 0755 "${src}" "${dst}"
  ok "installed: ${dst}"
}

model_src_path() { printf '%s' "${ROOT}/models/ggml-$1.bin"; }
model_dst_path() { printf '%s' "${MODELS_DIR}/ggml-$1.bin"; }

download_model_if_needed() {
  local slug="$1"
  local dl="${ROOT}/models/download-ggml-model.sh"
  [ -f "${dl}" ] || die "missing model downloader: ${dl}"

  local src
  src="$(model_src_path "${slug}")"

  if [ -s "${src}" ]; then
    ok "model source cached: $(basename "${src}")"
    return 0
  fi

  step "download (model ${slug})"
  (
    cd "${ROOT}"
    bash "./models/download-ggml-model.sh" "${slug}"
  ) 2>&1 | tee -a "${LOG_FILE}"

  [ -s "${src}" ] || die "model download failed: ${src}"
  ok "downloaded: $(basename "${src}")"
}

install_one_model_atomic() {
  local slug="$1"
  mkdir -p "${MODELS_DIR}"

  local src dst tmp
  src="$(model_src_path "${slug}")"
  dst="$(model_dst_path "${slug}")"
  tmp="${MODELS_DIR}/.ggml-${slug}.${timestamp}.tmp"

  [ -s "${src}" ] || die "missing downloaded model: ${src}"

  if [ -s "${dst}" ]; then
    local a b
    a="$(sha256 "${src}")"
    b="$(sha256 "${dst}")"
    if [ "${a}" = "${b}" ]; then
      ok "model already installed: $(basename "${dst}")"
      return 0
    fi
    warn "model exists but differs, replacing: $(basename "${dst}")"
  fi

  install -m 0644 "${src}" "${tmp}"
  mv -f "${tmp}" "${dst}"
  ok "installed model: $(basename "${dst}")"
}

write_contract() {
  step "contract"
  mkdir -p "${SHARE_DIR}"

  local engine="${BIN_DIR}/whisper-cli"
  local default_model="${MODEL_SLUGS[0]}"

  {
    echo "ASRYX_ENGINE=${engine}"
    echo "ASRYX_MODELS_DIR=${MODELS_DIR}"
    echo "ASRYX_DEFAULT_MODEL=${default_model}"
  } > "${CONTRACT_FILE}"

  ok "wrote: ${CONTRACT_FILE}"
}

create_user_env_if_missing() {
  step "user config"
  if [ -f "${USER_ENV_FILE}" ]; then
    ok "exists: ${USER_ENV_FILE} (leaving as is)"
    return 0
  fi
  local m="${MODEL_SLUGS[0]}"
  {
    echo "ASRYX_MODEL=${m}"
  } > "${USER_ENV_FILE}"
  ok "created: ${USER_ENV_FILE} (ASRYX_MODEL=${m})"
}

read_existing_models_from_manifest() {
  local file="$1"
  [ -f "$file" ] || return 0
  local line k v
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      model_path=*)
        v="${line#model_path=}"
        [ -n "$v" ] && echo "$v"
        ;;
    esac
  done < "$file"
}

write_manifest() {
  step "manifest"
  mkdir -p "${SHARE_DIR}"

  local engine="${BIN_DIR}/whisper-cli"
  local toggle="${BIN_DIR}/asryx"

  [ -x "${engine}" ] || die "engine missing: ${engine}"
  [ -x "${toggle}" ] || die "toggle missing: ${toggle}"

  declare -A models_map=()

  if [ -f "${MANIFEST_FILE}" ]; then
    while IFS= read -r p || [ -n "$p" ]; do
      if [ -n "$p" ] && [ -f "$p" ]; then
        models_map["$p"]="$(sha256 "$p")"
      fi
    done < <(read_existing_models_from_manifest "${MANIFEST_FILE}")
  fi

  local slug dst
  for slug in "${MODEL_SLUGS[@]}"; do
    dst="$(model_dst_path "${slug}")"
    [ -s "${dst}" ] || die "installed model missing: ${dst}"
    models_map["$dst"]="$(sha256 "$dst")"
  done

  {
    echo "app_id=${APP_ID}"
    echo "timestamp=${timestamp}"
    echo "prefix=${PREFIX}"
    echo "engine_repo_url=${ENGINE_REPO_URL}"
    echo "engine_sha=${ENGINE_SHA}"
    echo "workspace=${ROOT}"
    echo "build_dir=${BUILD}"
    echo "bin_dir=${BIN_DIR}"
    echo "share_dir=${SHARE_DIR}"
    echo "models_dir=${MODELS_DIR}"

    echo "contract_path=${CONTRACT_FILE}"
    echo "contract_sha256=$(sha256 "${CONTRACT_FILE}")"

    echo "engine_cli_path=${engine}"
    echo "engine_cli_sha256=$(sha256 "${engine}")"

    echo "toggle_path=${toggle}"
    echo "toggle_sha256=$(sha256 "${toggle}")"

    for dst in "${!models_map[@]}"; do
      echo "model_path=${dst}"
      echo "model_sha256=${models_map["$dst"]}"
    done
  } > "${MANIFEST_FILE}"

  ok "wrote: ${MANIFEST_FILE}"
}

verify_install() {
  step "verify"
  [ -x "${BIN_DIR}/whisper-cli" ] || die "missing: ${BIN_DIR}/whisper-cli"
  "${BIN_DIR}/whisper-cli" --help >>"${LOG_FILE}" 2>&1 || die "whisper-cli failed to run"
  [ -x "${BIN_DIR}/asryx" ] || die "missing: ${BIN_DIR}/asryx"
  ok "engine ok"
  ok "toggle ok"

  has_cmd notify-send || die "missing runtime tool: notify-send"
  (has_cmd pw-record || has_cmd arecord) || die "missing runtime tool: pw-record/arecord"
  (has_cmd wl-copy || has_cmd xclip) || die "missing runtime tool: wl-copy/xclip"
  ok "runtime tools ok"

  local slug dst
  for slug in "${MODEL_SLUGS[@]}"; do
    dst="$(model_dst_path "${slug}")"
    [ -s "${dst}" ] || die "missing model: ${dst}"
  done
  ok "models ok"

  _emit ""
  hr
  _emit "${bold}usage:${nc}"
  _emit "  asryx"
  _emit ""
  _emit "${bold}switch model:${nc}"
  _emit "  echo ASRYX_MODEL=large-v3-turbo > ~/.asryx.env"
  hr
}

main() {
  trap on_err ERR

  local t_all0 t_all1
  t_all0="$(ts_now)"

  parse_args "$@"
  log_setup

  detect_pm
  set_deps_for_pm
  pm_prepare_once

  set_paths
  print_plan
  confirm_plan
  sudo_warmup

  step "deps (build)"
  install_missing_pkgs "${DEPS_BUILD[@]}"
  ok "build deps satisfied"

  ensure_runtime_contract

  clone_or_update
  build_release
  install_engine_atomic
  install_toggle

  step "models"
  mkdir -p "${MODELS_DIR}"
  local slug
  for slug in "${MODEL_SLUGS[@]}"; do
    download_model_if_needed "${slug}"
    install_one_model_atomic "${slug}"
  done

  write_contract
  create_user_env_if_missing
  write_manifest
  verify_install

  t_all1="$(ts_now)"
  step "done"
  ok "installed asryx ($(dur "${t_all0}" "${t_all1}"))"
  ok "log: ${LOG_FILE}"
}

main "$@"
