#!/usr/bin/env bash
[ -n "${BASH_VERSION:-}" ] || exec bash "$0" "$@"
set -Eeuo pipefail

# ─────────────────────────────────────────────────────────────
# colors
# ─────────────────────────────────────────────────────────────
if [ -t 1 ]; then
  red=$'\033[0;31m'; green=$'\033[0;32m'; yellow=$'\033[0;33m'
  blue=$'\033[0;34m'; bold=$'\033[1m'; nc=$'\033[0m'
else
  red=''; green=''; yellow=''; blue=''; bold=''; nc=''
fi

log()  { printf "%b\n" "${blue}${bold}[*]${nc} $*"; }
ok()   { printf "%b\n" "${green}${bold}[ok]${nc} $*"; }
warn() { printf "%b\n" "${yellow}${bold}[warn]${nc} $*"; }

fail() {
  command -v notify-send >/dev/null 2>&1 && \
    notify-send -a asryx "asryx" "$*" >/dev/null 2>&1 || true
  printf "%b\n" "${red}${bold}[err]${nc} $*"
  exit 1
}

# ─────────────────────────────────────────────────────────────
# helpers
# ─────────────────────────────────────────────────────────────
require() { command -v "$1" >/dev/null 2>&1 || fail "missing: $1"; }

pid_alive() {
  [[ "$1" =~ ^[0-9]+$ ]] && kill -0 "$1" 2>/dev/null
}

threads_default() {
  command -v nproc >/dev/null 2>&1 && nproc || echo 4
}

copy_clip() {
  if command -v wl-copy >/dev/null 2>&1; then
    wl-copy <"$1"
  elif command -v xclip >/dev/null 2>&1; then
    xclip -selection clipboard -i "$1"
  else
    fail "no clipboard tool"
  fi
}

runtime_dir() {
  if [ -n "${XDG_RUNTIME_DIR:-}" ] && [ -w "$XDG_RUNTIME_DIR" ]; then
    echo "$XDG_RUNTIME_DIR"
  elif [ -d "/run/user/$UID" ]; then
    echo "/run/user/$UID"
  else
    echo "/tmp"
  fi
}

# ─────────────────────────────────────────────────────────────
# paths / contract
# ─────────────────────────────────────────────────────────────
PREFIX="$HOME/.local"
SHARE="$PREFIX/share/asryx"

CONTRACT="$SHARE/asryx.env"
USER_ENV="$HOME/.asryx.env"

[ -f "$CONTRACT" ] || fail "contract missing (run installer)"

# shellcheck disable=SC1090
source "$CONTRACT"
[ -f "$USER_ENV" ] && source "$USER_ENV" || true

ENGINE="${ASRYX_ENGINE:?}"
MODEL_RAW="${ASRYX_MODEL:?}"
LANG="${ASRYX_LANG:-}"
THREADS="${ASRYX_THREADS:-$(threads_default)}"

[ -x "$ENGINE" ] || fail "engine missing: $ENGINE"

# ─────────────────────────────────────────────────────────────
# model resolution (FIX)
# ─────────────────────────────────────────────────────────────
resolve_model() {
  local m="$1"

  # absolute or relative path
  if [[ "$m" == /* || "$m" == ./* || "$m" == ../* ]]; then
    echo "$m"
    return
  fi

  # explicit filename
  if [[ "$m" == *.bin ]]; then
    echo "$SHARE/models/$m"
    return
  fi

  # slug
  echo "$SHARE/models/ggml-$m.bin"
}

MODEL="$(resolve_model "$MODEL_RAW")"
[ -s "$MODEL" ] || fail "model missing: $MODEL_RAW"

require notify-send
require wc

# ─────────────────────────────────────────────────────────────
# state (GLOBAL SINGLE LOCK)
# ─────────────────────────────────────────────────────────────
STATE="$(runtime_dir)/asryx-$UID"
mkdir -p "$STATE"

LOCKDIR="$STATE/lock"
LOCKPID="$LOCKDIR/pid"

PID_FILE="$STATE/rec.pid"
WAV="$STATE/rec.wav"
OUT="$STATE/out"
TXT="$OUT.txt"
ERR="$STATE/rec.err"

# ─────────────────────────────────────────────────────────────
# lock handling (PID ONLY)
# ─────────────────────────────────────────────────────────────
acquire_lock() {
  if mkdir "$LOCKDIR" 2>/dev/null; then
    echo "$$" >"$LOCKPID"
    return
  fi

  if [ -f "$LOCKPID" ]; then
    holder="$(cat "$LOCKPID" 2>/dev/null || true)"
    if pid_alive "$holder"; then
      exit 0
    fi
  fi

  rm -rf "$LOCKDIR"
  mkdir "$LOCKDIR" || exit 0
  echo "$$" >"$LOCKPID"
}

release_lock() {
  [ "$(cat "$LOCKPID" 2>/dev/null)" = "$$" ] || return 0
  rm -rf "$LOCKDIR"
}

trap release_lock EXIT INT TERM

# ─────────────────────────────────────────────────────────────
# recorder selection
# ─────────────────────────────────────────────────────────────
if command -v pw-record >/dev/null 2>&1; then
  REC="pw-record"
elif command -v arecord >/dev/null 2>&1; then
  REC="arecord"
else
  fail "no recorder (pw-record/arecord)"
fi

# ─────────────────────────────────────────────────────────────
# main logic
# ─────────────────────────────────────────────────────────────
acquire_lock

# stop + transcribe
if [ -f "$PID_FILE" ]; then
  pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  if pid_alive "$pid"; then
    log "stopping recorder (pid $pid)"
    kill -INT "$pid" 2>/dev/null || true
    wait "$pid" 2>/dev/null || true
  fi
  rm -f "$PID_FILE"

  [ -s "$WAV" ] || exit 0

  log "transcribing…"
  args=(-m "$MODEL" -f "$WAV" -t "$THREADS" -otxt -of "$OUT")
  [ -n "$LANG" ] && args+=(-l "$LANG")

  "$ENGINE" "${args[@]}" >/dev/null 2>&1 || fail "transcription failed"
  [ -s "$TXT" ] || fail "no output"

  copy_clip "$TXT"
  ok "copied $(wc -w <"$TXT") words"
  notify-send -a asryx "asryx" "copied to clipboard" >/dev/null 2>&1 || true

  rm -f "$WAV" "$TXT" "$ERR"
  exit 0
fi

# start recording
rm -f "$WAV" "$ERR"

if [ "$REC" = "pw-record" ]; then
  pw-record --rate 16000 --channels 1 --format s16 "$WAV" >/dev/null 2>"$ERR" &
else
  arecord -q -f S16_LE -r 16000 -c 1 "$WAV" >/dev/null 2>"$ERR" &
fi

echo "$!" >"$PID_FILE"
ok "recording"
notify-send -a asryx "asryx" "recording…" >/dev/null 2>&1 || true
