#!/usr/bin/env bash
[ -n "${BASH_VERSION:-}" ] || exec bash "$0" "$@"

set -Eeuo pipefail
umask 022

timestamp="$(date +%Y%m%d-%H%M%S)"

APP_ID="asryx"
PREFIX_DEFAULT="${HOME}/.local"

AUTO_YES=0
PREFIX="${PREFIX_DEFAULT}"

PURGE_WORKSPACE_MODE="auto"
PURGE_MODELS_MODE="auto"
FORCE=0

if [ -t 1 ]; then
  red=$'\033[0;31m'
  green=$'\033[0;32m'
  yellow=$'\033[0;33m'
  blue=$'\033[0;34m'
  magenta=$'\033[0;35m'
  cyan=$'\033[0;36m'
  bold=$'\033[1m'
  dim=$'\033[2m'
  nc=$'\033[0m'
else
  red=''; green=''; yellow=''; blue=''; magenta=''; cyan=''; bold=''; dim=''; nc=''
fi

die() { printf "%b\n" "${red}${bold}error:${nc} $*" >&2; exit 1; }
ok() { printf "%b\n" "${green}${bold}✔${nc} $*"; }
warn() { printf "%b\n" "${yellow}${bold}⚠${nc} $*"; }
info() { printf "%b\n" "${blue}${bold}i${nc} $*"; }
step() { printf "\n%b\n" "${magenta}${bold}==>${nc} $*"; }
hr() { printf "%b\n" "${cyan}${dim}------------------------------------------------------------${nc}"; }

LOG_FILE=""

usage() {
  cat <<'EOF'
usage:
  ./package/uninstall [--yes|-y] [--prefix <path>]
                      [--purge-workspace|--keep-workspace]
                      [--purge-models|--keep-models]
                      [--force] [--help]

defaults:
  --prefix $HOME/.local
  purge-workspace: auto (only if it looks like owned whisper.cpp clone)
  purge-models:    auto (removes models recorded in manifest)
  --force bypasses sha verification and manifest gaps

notes:
  - ~/.asryx.env is never removed
  - system packages are never removed
EOF
}

parse_args() {
  while [ "${#}" -gt 0 ]; do
    case "$1" in
      --yes|-y) AUTO_YES=1 ;;
      --prefix) PREFIX="${2:-}"; [ -n "${PREFIX}" ] || die "missing value for --prefix"; shift ;;
      --purge-workspace) PURGE_WORKSPACE_MODE="yes" ;;
      --keep-workspace) PURGE_WORKSPACE_MODE="no" ;;
      --purge-models) PURGE_MODELS_MODE="yes" ;;
      --keep-models) PURGE_MODELS_MODE="no" ;;
      --force) FORCE=1 ;;
      --help|-h) usage; exit 0 ;;
      *) die "unknown arg: $1 (try --help)" ;;
    esac
    shift
  done
}

log_setup() {
  local cache_dir log_dir
  cache_dir="${XDG_CACHE_HOME:-${HOME}/.cache}"
  log_dir="${cache_dir}/${APP_ID}"
  mkdir -p "${log_dir}"
  LOG_FILE="${log_dir}/uninstall-${timestamp}.log"
  exec > >(tee -a "${LOG_FILE}") 2>&1
  info "log: ${LOG_FILE}"
}

on_err() {
  local code="$?"
  local line="${BASH_LINENO[0]:-?}"
  local cmd="${BASH_COMMAND:-?}"
  echo
  warn "failed (exit ${code})"
  warn "at line: ${line}"
  warn "cmd: ${cmd}"
  warn "log: ${LOG_FILE}"
  exit "${code}"
}

sha256() { sha256sum "$1" | awk '{print $1}'; }

BIN_DIR=""
SHARE_DIR=""
MODELS_DIR=""
CONTRACT_FILE=""
MANIFEST_FILE=""
DEFAULT_WORKSPACE=""

set_paths() {
  BIN_DIR="${PREFIX}/bin"
  SHARE_DIR="${PREFIX}/share/${APP_ID}"
  MODELS_DIR="${SHARE_DIR}/models"
  CONTRACT_FILE="${SHARE_DIR}/asryx.env"
  MANIFEST_FILE="${SHARE_DIR}/install.manifest"
  DEFAULT_WORKSPACE="${PREFIX}/opt/whisper.cpp"
}

confirm_plan() {
  if [ "${AUTO_YES}" -eq 1 ]; then
    ok "auto mode: skipping confirmation (--yes/-y)"
    return 0
  fi
  echo
  info "type ${bold}y${nc} to uninstall"
  printf "%buninstall now?%b " "${cyan}" "${nc}"
  local ans
  IFS= read -r ans || true
  [ "${ans:-}" = "y" ] || die "aborted"
}

print_plan() {
  step "plan"
  hr
  printf "%b\n" "${bold}asryx uninstaller${nc}"
  echo
  echo "prefix:       ${PREFIX}"
  echo "bin dir:      ${BIN_DIR}"
  echo "share dir:    ${SHARE_DIR}"
  echo "models dir:   ${MODELS_DIR}"
  echo "contract:     ${CONTRACT_FILE}"
  echo "manifest:     ${MANIFEST_FILE}"
  echo "workspace:    ${DEFAULT_WORKSPACE}"
  echo "purge ws:     ${PURGE_WORKSPACE_MODE}"
  echo "purge models: ${PURGE_MODELS_MODE}"
  echo "force:        $([ "${FORCE}" -eq 1 ] && echo yes || echo no)"
  hr
  echo "notes:"
  echo "  - ~/.asryx.env is never removed"
  echo "  - system packages are never removed"
  echo "  - without a manifest, nothing is removed unless --force"
  hr
}

require_manifest_or_force() {
  if [ -f "${MANIFEST_FILE}" ]; then
    return 0
  fi
  if [ "${FORCE}" -eq 1 ]; then
    warn "manifest missing, proceeding because --force"
    return 0
  fi
  die "manifest not found at ${MANIFEST_FILE} (use --force if you insist)"
}

remove_file_if_matches_manifest() {
  local path="$1" expected_sha="$2" label="$3"

  if [ ! -e "${path}" ] && [ ! -L "${path}" ]; then
    ok "${label}: not present (skipping)"
    return 0
  fi

  if [ "${FORCE}" -eq 1 ]; then
    rm -f "${path}"
    ok "${label}: removed (--force)"
    return 0
  fi

  [ -n "${expected_sha}" ] || die "${label}: manifest sha missing (refusing): ${path}"

  if [ ! -f "${path}" ]; then
    warn "${label}: not a regular file; leaving in place: ${path}"
    return 0
  fi

  local got
  got="$(sha256 "${path}")"
  if [ "${got}" != "${expected_sha}" ]; then
    warn "${label}: sha mismatch; leaving in place"
    warn "expected: ${expected_sha}"
    warn "got:      ${got}"
    warn "path:     ${path}"
    return 0
  fi

  rm -f "${path}"
  ok "${label}: removed"
}

prune_empty_dirs() {
  local dir="$1"
  [ -d "${dir}" ] || return 0
  rmdir "${dir}" 2>/dev/null || true
}

workspace_looks_owned() {
  local workspace="$1"
  [ -d "${workspace}/.git" ] || return 1
  command -v git >/dev/null 2>&1 || return 1
  local url
  url="$(git -C "${workspace}" config --get remote.origin.url 2>/dev/null || true)"
  case "${url}" in
    *github.com/ggml-org/whisper.cpp.git|*github.com:ggml-org/whisper.cpp.git) return 0 ;;
    *github.com/ggml-org/whisper.cpp|*github.com:ggml-org/whisper.cpp) return 0 ;;
    *) return 1 ;;
  esac
}

remove_workspace_auto_safe() {
  step "remove (workspace)"

  if [ "${PURGE_WORKSPACE_MODE}" = "no" ]; then
    ok "workspace: keep-workspace (leaving)"
    return 0
  fi

  local ws
  ws="${DEFAULT_WORKSPACE}"
  if [ ! -d "${ws}" ]; then
    ok "workspace not present (skipping)"
    return 0
  fi

  if [ "${PURGE_WORKSPACE_MODE}" = "yes" ] || [ "${FORCE}" -eq 1 ]; then
    rm -rf "${ws}"
    ok "workspace removed"
    return 0
  fi

  if workspace_looks_owned "${ws}"; then
    rm -rf "${ws}"
    ok "workspace removed (auto-safe)"
  else
    warn "workspace does not look like owned whisper.cpp clone; leaving in place"
    warn "path: ${ws}"
  fi
}

main() {
  trap on_err ERR

  parse_args "$@"
  log_setup
  set_paths

  print_plan
  confirm_plan
  require_manifest_or_force

  step "read manifest"
  local engine_cli_path="" engine_cli_sha=""
  local toggle_path="" toggle_sha=""
  local contract_path="" contract_sha=""
  local models_dir=""
  local -a model_paths=()
  local -a model_shas=()

  local line key val
  while IFS= read -r line || [ -n "$line" ]; do
    [[ "$line" == *=* ]] || continue
    key="${line%%=*}"
    val="${line#*=}"
    case "$key" in
      engine_cli_path) engine_cli_path="$val" ;;
      engine_cli_sha256) engine_cli_sha="$val" ;;
      toggle_path) toggle_path="$val" ;;
      toggle_sha256) toggle_sha="$val" ;;
      contract_path) contract_path="$val" ;;
      contract_sha256) contract_sha="$val" ;;
      models_dir) models_dir="$val" ;;
      model_path) model_paths+=("$val") ;;
      model_sha256) model_shas+=("$val") ;;
    esac
  done < "${MANIFEST_FILE}"

  [ -n "${engine_cli_path}" ] || engine_cli_path="${BIN_DIR}/whisper-cli"
  [ -n "${toggle_path}" ] || toggle_path="${BIN_DIR}/asryx"
  [ -n "${contract_path}" ] || contract_path="${CONTRACT_FILE}"
  [ -n "${models_dir}" ] || models_dir="${MODELS_DIR}"

  step "remove (bin)"
  remove_file_if_matches_manifest "${engine_cli_path}" "${engine_cli_sha}" "whisper-cli"
  remove_file_if_matches_manifest "${toggle_path}" "${toggle_sha}" "asryx"

  step "remove (contract)"
  remove_file_if_matches_manifest "${contract_path}" "${contract_sha}" "asryx internal contract"

  step "remove (models)"
  if [ "${PURGE_MODELS_MODE}" = "no" ]; then
    ok "models: keep-models (leaving)"
  else
    local i p s
    for i in "${!model_paths[@]}"; do
      p="${model_paths[$i]}"
      s=""
      if [ "$i" -lt "${#model_shas[@]}" ]; then
        s="${model_shas[$i]}"
      fi
      if [ -n "$p" ]; then
        remove_file_if_matches_manifest "$p" "$s" "model"
      fi
    done
  fi

  step "remove (manifest)"
  rm -f "${MANIFEST_FILE}" 2>/dev/null || true
  ok "removed manifest"

  prune_empty_dirs "${models_dir}"
  prune_empty_dirs "${SHARE_DIR}"

  remove_workspace_auto_safe

  step "done"
  ok "uninstall finished"
  ok "log: ${LOG_FILE}"
}

main "$@"
