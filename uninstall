#!/usr/bin/env bash
set -Eeuo pipefail

repo_dir="${ASRYX_REPO_DIR:-${HOME}/.local/opt/asryx}"
whisper_dir="${ASRYX_WHISPER_DIR:-${HOME}/.local/opt/whisper.cpp}"
bin_dir="${ASRYX_BIN_DIR:-${HOME}/.local/bin}"
share_dir="${ASRYX_SHARE_DIR:-${HOME}/.local/share/asryx}"
cache_dir="${ASRYX_CACHE_DIR:-${HOME}/.cache/asryx}"
config_path="${ASRYX_CONFIG_PATH:-${HOME}/.asryx.conf}"
runtime_dir="${XDG_RUNTIME_DIR:-/tmp}/asryx"
fallback_runtime_dir="/tmp/asryx-$(id -u)"

log() {
  printf 'asryx uninstall: %s\n' "$*"
}

die() {
  printf 'asryx uninstall: error: %s\n' "$*" >&2
  exit 1
}

require_home() {
  [[ -n "${HOME:-}" ]] || die "HOME is not set"
  [[ "${HOME}" != "/" ]] || die "HOME resolved to /; refusing to continue"
}

is_allowed_path() {
  local path="$1"
  case "${path}" in
    "${HOME}/.local/bin/asryx" | \
      "${HOME}/.local/bin/whisper-cli" | \
      "${HOME}/.local/opt/asryx" | \
      "${HOME}/.local/opt/whisper.cpp" | \
      "${HOME}/.local/share/asryx" | \
      "${HOME}/.cache/asryx" | \
      "${HOME}/.asryx.conf" | \
      "${runtime_dir}" | \
      "${fallback_runtime_dir}")
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

remove_path() {
  local path="$1"
  is_allowed_path "${path}" || die "refusing to remove unowned path: ${path}"

  if [[ -e "${path}" || -L "${path}" ]]; then
    log "removing ${path}"
    rm -rf -- "${path}"
  else
    log "already absent: ${path}"
  fi
}

main() {
  require_home
  log "this uninstaller will remove exactly these paths when present:"
  printf '  - %s\n' \
    "${bin_dir}/asryx" \
    "${bin_dir}/whisper-cli" \
    "${repo_dir}" \
    "${whisper_dir}" \
    "${share_dir}" \
    "${cache_dir}" \
    "${config_path}" \
    "${runtime_dir}" \
    "${fallback_runtime_dir}"

  remove_path "${bin_dir}/asryx"
  remove_path "${bin_dir}/whisper-cli"
  remove_path "${repo_dir}"
  remove_path "${whisper_dir}"
  remove_path "${share_dir}"
  remove_path "${cache_dir}"
  remove_path "${config_path}"
  remove_path "${runtime_dir}"
  remove_path "${fallback_runtime_dir}"
  log "done"
}

main "$@"
